@using Sandbox;
@using Sandbox.UI;
@using System;
@using System.Collections.Generic;
@namespace MenuProject.Rewards
@inherits PanelComponent

<root>

	<div class="topbar">
		<Button class="clicky back" Icon="west" Text="Back" @onclick="@Back" />
	</div>

	@if ( IsLoading )
	{
		<div class="center">
			<div class="spinner">
				<icon>hourglass_empty</icon>
			</div>
		</div>
	}
	else if ( Offer is null )
	{
		<div class="center">
			<label class="title">Nothing to open right now.</label>
			<label class="sub">Jump into a game to receive your reward drop.</label>
			<Button class="clicky" Text="Back" Icon="west" @onclick="@Back" />
		</div>
	}
	else if ( Result is not null && Result.Success )
	{
		<div class="center">
			<label class="eyebrow">You unwrapped</label>

			<div class="items">
				@foreach ( var item in Result.Items )
				{
					<RewardUnboxItem Revealed="@true" Item="@item" Selected="@true" />
				}
			</div>

			<Button class="clicky primary" Text="Done" Icon="check" @onclick="@Back" />
		</div>
	}
	else
	{
		<div class="center">
			<div class="window">

				<div class="header">
					<label class="screen-title">Reward Drop</label>
					<label class="screen-subtitle">Congratulations - you are receiving a reward! This item will be added to your inventory on Steam and you'll be able to wear it in the avatar editor. If you don't want the item you'll be able to use Steam's Marketplace system to trade or sell it.</label>
				</div>

				<div class="choose">
					<div class="items">
						@for ( int i = 0; i < Offer.Items.Length; i++ )
						{
							var item = Offer.Items[i];
							<RewardUnboxItem Item="@item" Selected="@IsPicked( item.ItemDefId )" OnSelect="@( () => TogglePick( item.ItemDefId ) )" OnRevealed="@OnCardBroken" />
						}
					</div>
				</div>

				<div class="footer @( ShowSidebar ? "show" : "" )">
					<div class="column">
						<div class="select-banner">
							<label>Select up to @Offer.PickCount @( Offer.PickCount == 1 ? "Reward" : "Rewards" )</label>
						</div>
						<label class="blurb">Pick your item — they're yours to keep, free.</label>
					</div>

					<Button class="clicky claim" Text="@ClaimText" Icon="redeem" Disabled="@( !CanConfirm )" @onclick="@Confirm" />
				</div>

			</div>
		</div>
	}

</root>

@code
{
	/// <summary>The offer being opened, claimed from the backend when this scene loads.</summary>
	RewardOffer Offer { get; set; }

	/// <summary>The result once the player has committed their pick, otherwise null.</summary>
	RewardResult Result { get; set; }

	/// <summary>The items the player has selected so far.</summary>
	List<long> Picked { get; } = new();

	/// <summary>True while we're claiming the offer from the backend.</summary>
	bool IsLoading { get; set; }

	/// <summary>True while the ChooseReward call is in flight.</summary>
	bool IsChoosing { get; set; }

	/// <summary>How many of the offer's boxes the player has smashed open so far.</summary>
	int RevealedCount { get; set; }

	/// <summary>True once every box is open and the options panel should slide in.</summary>
	bool ShowSidebar { get; set; }

	bool _hasLoaded;

	protected override void OnEnabled()
	{
		base.OnEnabled();

		if ( _hasLoaded )
			return;

		_hasLoaded = true;
		_ = LoadOffer();
	}

	async Task LoadOffer()
	{
		IsLoading = true;
		Offer = await MenuUtility.Rewards.ClaimReward();
		IsLoading = false;
	}

	/// <summary>A box has been smashed open. Once every box is open, bring in the options panel.</summary>
	void OnCardBroken()
	{
		RevealedCount++;

		if ( Offer is not null && RevealedCount >= Offer.Items.Length )
			ShowSidebar = true;
	}

	string ClaimText => IsChoosing ? "Claiming…" : "Claim";

	bool IsPicked( long itemDefId ) => Picked.Contains( itemDefId );

	/// <summary>You can confirm once you've picked exactly the number of items the offer allows.</summary>
	bool CanConfirm
	{
		get
		{
			if ( Offer is null )
				return false;

			if ( Result is not null )
				return false;

			if ( IsChoosing )
				return false;

			return Picked.Count == Offer.PickCount;
		}
	}

	/// <summary>
	/// Toggle an item in the player's selection. When the offer only lets you keep one item,
	/// picking a new one replaces the old.
	/// </summary>
	void TogglePick( long itemDefId )
	{
		if ( Offer is null )
			return;

		if ( Result is not null )
			return;

		if ( Picked.Contains( itemDefId ) )
		{
			Picked.Remove( itemDefId );
			return;
		}

		if ( Picked.Count >= Offer.PickCount )
		{
			if ( Offer.PickCount == 1 )
				Picked.Clear();
			else
				return;
		}

		Picked.Add( itemDefId );
	}

	void Confirm()
	{
		if ( !CanConfirm )
			return;

		IsChoosing = true;
		_ = ConfirmAsync();
	}

	async Task ConfirmAsync()
	{
		var choice = new RewardChoice();
		choice.DropId = Offer.DropId;
		choice.ItemDefIds = Picked.ToArray();

		Result = await MenuUtility.Rewards.ChooseReward( choice );
		IsChoosing = false;

		if ( Result.Success )
			Burst();
	}

	/// <summary>Fire the confetti when the player commits their pick.</summary>
	void Burst()
	{
		foreach ( var emitter in Scene.GetAll<ParticleEmitter>() )
		{
			emitter.ResetEmitter();
		}
	}

	/// <summary>Return to the main menu, which rebuilds the front page and refreshes the reward progress.</summary>
	void Back()
	{
		var options = new SceneLoadOptions();
		options.ShowLoadingScreen = true;
		options.SetScene( "/scenes/menu-main.scene" );

		Game.ActiveScene.Load( options );
	}

	protected override int BuildHash() => HashCode.Combine( IsLoading, Offer, Result, IsChoosing, Picked.Count, RevealedCount, ShowSidebar );
}
